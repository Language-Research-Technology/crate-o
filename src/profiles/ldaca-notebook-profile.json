{
  "metadata": {
    "name": "Language Data Commons Jupyter Notebook",
    "description": "RO-Crate editor profile for a Jupyter Notebook",
    "version": "0.0.1"
  },
  "rootDatasets": {
    "Schema": {
      "type": "Dataset"
    }
  },
  "hide": {"Dataset": []},

  "classes": {
    "Dataset": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "http://purl.org/dc/terms/conformsTo",
          "name": "conformsTo",
          "help": "The URL for 'Workflow RO-Crate profile 1.0'",
          "type": [
            "SelectUrl"
          ],
          "values": [
            "https://w3id.org/workflowhub/workflow-ro-crate/1.0"
          ],
          "multiple": false
        },
        {
          "id": "https://schema.org/name",
          "name": "name",
          "label": "Name",
          "help": "The name of this notebook",
          "required": true,
          "multiple": false,
          "type": [
            "Text"
          ]
        },
        {
          "id": "http://schema.org/creditText",
          "name": "creditText",
          "help": "A text based citation for this notebook data package",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "https://schema.org/datePublished",
          "name": "datePublished",
          "help": "Date of this release",
          "type": [
            "Date"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/author",
          "name": "author",
          "help": "The person or organization responsible for creating this collection of notebook",
          "type": [
            "Person",
            "Organization"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/publisher",
          "name": "publisher",
          "help": "The organization responsible for releasing this notebook",
          "type": [
            "Organization"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/funder",
          "name": "funder",
          "help": "Organization(s) responsible for funding the creation of this notebook",
          "type": [
            "Organization"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/citation",
          "name": "citation",
          "help": "Associated Publications",
          "type": [
            
            "CreativeWork"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/description",
          "name": "description",
          "help": "An abstract of the notebook. Include as much detail as possible about the motivation and use of the collection, including things that we do not yet have properties for",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
       
        {
          "id": "http://schema.org/mainEntity",
          "name": "mainEntity",
          "help": "Indicates the Main Workflow",
          "type": [
            "File"
          ],
          "multiple": true
        }
      ]
    },
    
    "CreativeWork": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "https://schema.org/name",
          "name": "name",
          "label": "Name",
          "help": "The name of this collection",
          "required": true,
          "multiple": false,
          "type": [
            "Text"
          ]
        },
        {
          "id": "http://schema.org/description",
          "name": "description",
          "help": "An abstract of the work",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "http://schema.org/creditText",
          "name": "creditText",
          "help": "A text based citation for this work",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "http://schema.org/author",
          "name": "author",
          "help": "The person or organization responsible for creating this work",
          "type": [
            "Person",
            "Organization"
          ],
          "multiple": true
        },
        {
          "id": "http://schema.org/description",
          "name": "description",
          "help": "A description of the collection",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "http://schema.org/datePublished",
          "name": "datePublished",
          "help": "The date this work was published",
          "type": [
            "Date"
          ],
          "multiple": false
        },
        {
          "id": "http://schema.org/publisher",
          "name": "publisher",
          "help": "The Organization that published this work (use ROR IDs for institutions)",
          "type": [
            "Organization", "Text"
          ],
          "multiple": false
        }
      ]
    },
    "Person": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "https://schema.org/name",
          "name": "name",
          "label": "name",
          "help": "The name the person",
          "required": true,
          "multiple": false,
          "type": [
            "Text"
          ]
        },
        {
          "id": "http://schema.org/description",
          "name": "description",
          "help": "Add any additional info not covered by other properties here.",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "https://schema.org/affiliation",
          "name": "affiliation",
          "label": "affiliation",
          "help": "The oganizational affiliation for a person",
          "required": false,
          "multiple": true,
          "type": [
            "Organization", "Text"
          ]
        }
      ]
    },
    "Organization": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "https://schema.org/name",
          "name": "name",
          "label": "name",
          "help": "The name of the organization",
          "required": true,
          "multiple": false,
          "type": [
            "Text"
          ]
        },
        {
          "id": "http://schema.org/description",
          "name": "description",
          "help": "A description of the organization",
          "type": [
            "TextArea"
          ],
          "multiple": false
        },
        {
          "id": "http://schema.org/location",
          "name": "location",
          "help": "A location for the organization (eg a city for a publisher)",
          "type": [
            "Text"
          ],
          "multiple": false
        }
      ]
    },
    "File": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "https://schema.org/encodingFormat",
          "name": "encodingFormat",
          "help": "Media type typically expressed using a MIME format",
          "type": [
            "Text"
          ]
        },
        {
          "id": "https://purl.archive.org/language-data-commons/terms#size",
          "name": "size",
          "help": "Size in Bytes",
          "type": [
            "Text"
          ]
        }
      ]
    },
    "SoftwareSourceCode": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
        {
          "id": "https://schema.org/programmingLanguage",
          "name": "programmingLanguage",
          "help": "Media type typically expressed using a MIME format",
          "type": [
            "ComputerLanguage"
          ]
        }
      ]
    },
    "ComputationalWorkflow": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
      ]
    },
    "ComputerLanguage": {
      "definition": "override",
      "subClassOf": [],
      "inputs": [
      ]
    },
    "Language": {
      "definition": "override"
    }
  },
  "lookup": {
    "Language": {
      "fields": [
        "@id",
        "name",
        "alternateName",
        "iso639-3",
        "austlangCode",
        "glottologCode",
        "languageCode"
      ]
    },
    "Organization": {
      "module": "ror"
    }
  },
  "enabledClasses": [
    "Dataset",
    "Person",
    "Organization",
    "Book",
    "ScholarlyArticle",
    "RepositoryCollection",
    "CreativeWork",
    "CollectionProtocol",
    "File",
    "Language",
    "ComputationalWorkflow",
    "SoftwareSourceCode"
  ]
}   